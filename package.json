{
  "name": "prismacloak",
  "version": "0.1.0",
  "description": "Anonymize Prisma schemas for safe LLM context — preserve relations, hide domain names.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "prismacloak": "./dist/cli.js"
  },
  "files": [
    "dist",
    "action.yml",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "demo": "tsx src/cli.ts demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:fixture": "npm run build && node dist/cli.js cloak test/fixtures/sample.schema.prisma && node dist/cli.js check --schema test/fixtures/sample.schema.prisma",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "prisma",
    "llm",
    "security",
    "schema",
    "redaction",
    "anonymize",
    "ai",
    "cli",
    "cursor",
    "claude",
    "chatgpt"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/internals": "^6.19.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
